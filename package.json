{
  "name": "ucat-trainer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "npx eslint .",
    "verify:qr-maths": "tsx scripts/verify-qr-question-maths.ts",
    "seed:syllogisms": "tsx scripts/seedSyllogisms.ts",
    "unify:bullet1-audit": "node scripts/unify-bullet1-audit.mjs",
    "unify:check-migrations": "node scripts/check-migrations-trainer-safe.mjs",
    "unify:trainer-smoke": "npm run lint && npm run build",
    "unify:planner-typecheck": "npm run build",
    "unify:planner-build": "npm run build",
    "unify:planner-lint": "npm run lint",
    "unify:bullet2-verify": "npm run unify:bullet2-verify-ci",
    "unify:planner-install-and-verify": "node scripts/uk-planner-install-verify.mjs",
    "unify:bullet2-verify-ci": "npm run unify:bullet1-guard && npm run unify:planner-install-and-verify",
    "unify:bullet8-verify": "npm run unify:bullet2-verify-ci",
    "unify:checklist-automated": "npm run unify:bullet2-verify-ci",
    "unify:manual-bullets": "node scripts/unify-manual-bullets-reminder.mjs",
    "unify:merge-preflight": "npm run unify:bullet1-audit && npm run unify:check-migrations && npm run unify:submit-sql",
    "unify:submit-sql": "node scripts/concat-migrations.mjs",
    "unify:release-gate-automated": "npm run unify:bullet2-verify-ci",
    "unify:bullet5-verify": "npm run unify:bullet1-guard",
    "unify:bullet1-guard": "npm run unify:check-migrations && npm run unify:trainer-smoke"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@supabase/supabase-js": "^2.95.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.574.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.1",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}

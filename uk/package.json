{
  "name": "uk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/strip-next-swc-quarantine.mjs",
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node -e \"const fs=require('fs');['.next','next.lock'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\" && node ./node_modules/next/dist/bin/next build --webpack",
    "postbuild": "node scripts/strip-next-ci-tsconfig.mjs",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js . && node scripts/check-no-en-em-dash.mjs && node scripts/regression-unify-matrix.mjs",
    "check:unify-matrix": "node scripts/regression-unify-matrix.mjs"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.9",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "eslint": "^9"
  },
  "devDependencies": {
    "node-exports-info": "^1.6.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
